#!/usr/bin/env bash
# fledge-plugin-jwt — A fledge plugin for JWT info and stuff
set -euo pipefail

# Colors
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

usage() {
  cat <<EOF
${YELLOW}fledge jwt${NC} — A fledge plugin for JWT info and stuff

${CYAN}USAGE:${NC}
  fledge jwt [SUBCOMMAND] [OPTIONS] [ARGS]

${CYAN}SUBCOMMANDS:${NC}
  decode <token>    Decode and print JWT header and payload
  ui                Open the interactive web inspector
  help              Print this message

${CYAN}EXAMPLES:${NC}
  fledge jwt decode eyJhbGc...
  fledge jwt ui
EOF
}

decode_part() {
  local part=$1
  # Add padding if needed
  local len=${#part}
  local rem=$((len % 4))
  if [ $rem -eq 2 ]; then
    part="${part}=="
  elif [ $rem -eq 3 ]; then
    part="${part}="
  fi
  # Base64URL to Base64
  echo "$part" | tr '_-' '/+' | base64 -d 2>/dev/null || echo "$part" | tr '_-' '/+' | base64 -D 2>/dev/null
}

decode_jwt() {
  local token=$1
  if [[ ! "$token" =~ ^[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+$ ]]; then
    echo -e "${RED}Error:${NC} Invalid JWT format." >&2
    exit 1
  fi

  local header_encoded=$(echo "$token" | cut -d. -f1)
  local payload_encoded=$(echo "$token" | cut -d. -f2)

  echo -e "${BLUE}Header:${NC}"
  decode_part "$header_encoded" | jq . || echo -e "${RED}Failed to parse header as JSON${NC}"

  echo -e "\n${GREEN}Payload:${NC}"
  decode_part "$payload_encoded" | jq . || echo -e "${RED}Failed to parse payload as JSON${NC}"
}

if [ $# -eq 0 ]; then
  usage
  exit 0
fi

case "$1" in
  decode)
    if [ -z "${2:-}" ]; then
      echo -e "${RED}Error:${NC} Missing JWT token." >&2
      exit 1
    fi
    decode_jwt "$2"
    ;;
  ui)
    # Find the docs/index.html file relative to the plugin location
    # Since fledge runs this binary, we can try to find where it's installed
    # For now, assume it's in the current repo if we're developing, or find the plugin path
    PLUGIN_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
    INDEX_FILE="$PLUGIN_DIR/docs/index.html"
    if [ -f "$INDEX_FILE" ]; then
      echo -e "${CYAN}Opening web inspector...${NC}"
      open "$INDEX_FILE"
    else
      echo -e "${RED}Error:${NC} Could not find index.html at $INDEX_FILE" >&2
      exit 1
    fi
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    echo -e "${RED}Error:${NC} Unknown subcommand '$1'" >&2
    usage
    exit 64
    ;;
esac

